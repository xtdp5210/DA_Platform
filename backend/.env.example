# ============================================================
#  DA Platform — Backend Environment Variables
#  Render → your service → Environment tab → add each key/value
#  THIS FILE IS SAFE TO COMMIT — it contains NO real secrets.
#  Put your actual values only in Render's Environment tab.
# ============================================================

# ── Django Core ─────────────────────────────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=CHANGE_ME_generate_with_command_above

DEBUG=False

# Your Render service URL, e.g.  da-platform-api.onrender.com
ALLOWED_HOSTS=da-platform-api.onrender.com

# ── Database (Neon PostgreSQL — neon.tech) ───────────────────
# Dashboard → your project → Connection Details → split the URL:
# postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASSWORD=CHANGE_ME_neon_db_password
DB_HOST=ep-twilight-pine-a1g1jd2f-pooler.ap-southeast-1.aws.neon.tech
DB_PORT=5432
DB_SSLMODE=require
DB_CHANNEL_BINDING=require

# ── CORS ────────────────────────────────────────────────────
# Your Vercel frontend URL — no trailing slash
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# ── Email (Gmail SMTP) ───────────────────────────────────────
EMAIL_HOST_USER=CHANGE_ME_your_gmail
# Use a Gmail App Password (not your main password):
# Google Account → Security → 2-Step Verification → App Passwords
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx

# ── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-CHANGE_ME

# ── Razorpay ─────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=CHANGE_ME_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME_webhook_secret

# ── UPI / Bank Transfer (loaded from env — never hardcoded) ──
# These appear inside every generated payment QR code.
# They are NOT secrets but stored here so a bank change needs no code edit.
UPI_ACCOUNT_NO=50100238058183
UPI_IFSC=HDFC0009297
UPI_ACCOUNT_NAME=RASHTRIYA RAKSHA UNIVERSITY

# ── Local SQLite switch (LOCAL DEV ONLY — never set True on Render) ─────────
# USE_SQLITE=True

# ── HTTPS / Security (SET ALL TO TRUE IN PRODUCTION) ─────────
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
# 1 year in seconds — only set after you are sure HTTPS is stable
SECURE_HSTS_SECONDS=31536000

# ── Superuser (created automatically by build.sh on first deploy) ──────────
# These are used ONCE to bootstrap the admin account — you can remove them
# from Render's env vars after the first successful deploy if you want.
DJANGO_SUPERUSER_EMAIL=admin@yourdomain.com
DJANGO_SUPERUSER_PASSWORD=CHANGE_ME_strong_admin_password
